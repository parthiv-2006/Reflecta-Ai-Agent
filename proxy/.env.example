# reflecta proxy configuration — copy to .env and fill in. NEVER commit real values.

# Operator's provider keys (paid, no-train tier recommended — see README).
GEMINI_API_KEY=
GROQ_API_KEY=

# Issued reflecta tokens and their daily call quotas.
# JSON form (per-token quota):
#   REFLECTA_TOKENS={"tok_alice": {"daily_quota": 200}, "tok_bob": {"daily_quota": 500}}
# or a bare comma-separated list using the default quota:
#   REFLECTA_TOKENS=tok_alice,tok_bob
REFLECTA_TOKENS=

# Default per-token daily call cap (used when a token has no explicit quota).
REFLECTA_DEFAULT_DAILY_QUOTA=200

# Reject prompts larger than this many characters.
REFLECTA_MAX_PROMPT_CHARS=200000
