# Bring-your-own-key (direct) mode — get free keys from Google AI Studio + Groq.
GEMINI_API_KEY=
GROQ_API_KEY=

# Remote (key-broker) mode — INSTEAD of the keys above, authenticate to a hosted
# reflecta proxy that runs on the operator's keys. Prefer `reflecta login`, which
# stores this in ~/.reflecta/credentials; these env vars are an alternative.
# When REFLECTA_TOKEN is set it takes precedence and no provider keys are needed.
# REFLECTA_TOKEN=
# REFLECTA_PROXY_URL=https://your-proxy.example   # optional; overrides the default
